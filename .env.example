# ── Amazon Bedrock ───────────────────────────────────────────────────────────
#
# All three variables are SERVER-SIDE ONLY. Never expose them to the browser.
# Add them to Vercel → Project Settings → Environment Variables (Production + Preview).
#

# Bearer token for Amazon Bedrock API authentication.
# Obtain  : Bedrock console → API keys → LONG-TERM tab → Create.
#           https://console.aws.amazon.com/bedrock/home#/api-keys/long-term/create
# WARNING : Use a LONG-TERM key. Short-term keys expire in ~12 hours and will
#           silently break a deployed app. Long-term keys do not expire until
#           you delete them.
AWS_BEARER_TOKEN_BEDROCK=

# AWS region where Bedrock is enabled for your account.
# Format  : standard AWS region identifier (lowercase, hyphenated).
# Options : ap-south-1 (Mumbai) | us-east-1 (N. Virginia) | us-west-2 (Oregon)
# Note    : Claude Sonnet 4.6 availability varies by region — verify in the
#           Bedrock console before setting. Mumbai (ap-south-1) is preferred for
#           India-latency reasons.
# Example : BEDROCK_REGION=ap-south-1
BEDROCK_REGION=ap-south-1

# Bedrock model ID — a cross-region INFERENCE PROFILE id, not the bare model id.
# From ap-south-1 (Mumbai) the model is not available in-region, so you MUST use
# the GLOBAL profile (the "global." prefix). Confirm access in Bedrock console →
# Model access for your region.
#   Haiku 4.5  (cheaper/faster) : global.anthropic.claude-haiku-4-5-20251001-v1:0
#   Sonnet 4.6 (more accurate)  : global.anthropic.claude-sonnet-4-6
BEDROCK_MODEL_ID=global.anthropic.claude-haiku-4-5-20251001-v1:0
