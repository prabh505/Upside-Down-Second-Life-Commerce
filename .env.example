# ── Amazon Bedrock ───────────────────────────────────────────────────────────
#
# All three variables are SERVER-SIDE ONLY. Never expose them to the browser.
# Add them to Vercel → Project Settings → Environment Variables (Production + Preview).
#

# Bearer token for Amazon Bedrock API authentication.
# Format : a raw AWS bearer token string (not Base64, not prefixed).
# Obtain  : AWS Console → Bedrock → API Keys, or via your AWS administrator.
# Example : AWS_BEARER_TOKEN_BEDROCK=eyJhbGciOiJSUzI1NiJ9...
AWS_BEARER_TOKEN_BEDROCK=

# AWS region where Bedrock is enabled for your account.
# Format  : standard AWS region identifier (lowercase, hyphenated).
# Options : ap-south-1 (Mumbai) | us-east-1 (N. Virginia) | us-west-2 (Oregon)
# Note    : Claude Sonnet 4.6 availability varies by region — verify in the
#           Bedrock console before setting. Mumbai (ap-south-1) is preferred for
#           India-latency reasons.
# Example : BEDROCK_REGION=ap-south-1
BEDROCK_REGION=ap-south-1

# Bedrock model ID for Claude Sonnet 4.6 (Converse API identifier).
# Format  : anthropic.<model-slug>-<version>:<minor>
# Obtain  : Bedrock console → Model access → Claude Sonnet → copy Model ID.
# Note    : Pin to a specific version to prevent silent API changes.
# Example : BEDROCK_MODEL_ID=anthropic.claude-sonnet-4-5-20251101-v1:0
BEDROCK_MODEL_ID=anthropic.claude-sonnet-4-5-20251101-v1:0
